---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { XMLParser } from 'fast-xml-parser';

const featuredIds = [
  "fUR55xr-Zv4",
  "l8Uh7IeYknk",
  "eenpqYDLKS4"
];

let latestVideos = [];

try {

  const rss =
    "https://www.youtube.com/feeds/videos.xml?channel_id=UCdBy3xmvJz_JQWGjydtbhEg";

  const response = await fetch(rss);

  const xml = await response.text();

  const parser = new XMLParser({
    ignoreAttributes: false
  });

  const data = parser.parse(xml);

  latestVideos =
    (data.feed.entry ?? [])
      .map((video) => {

        const id =
          video["yt:videoId"];

        return {

          id,

          title: video.title,

          published: new Date(video.published).toLocaleDateString(),

          thumbnail:
            `https://img.youtube.com/vi/${id}/hqdefault.jpg`

        };

      })
      .filter(video => !featuredIds.includes(video.id));

}
catch(err){

  console.log(err);

}
---

<BaseLayout title="Preachings | Belur Lokenath Mandir">

<PageHero
  eyebrow="Preachings"
  title="Videos & Spiritual Discourses"
  subtitle="Watch spiritual talks, prayers and messages of Maharaj Monu Baba."
/>

<section class="section">

<div class="container">

<h2>
